PORT=3000
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

AI_PROVIDER=auto
AI_TIMEOUT_MS=45000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
AUTH_CODE_SECRET=
OAUTH_STATE_SECRET=
ALLOW_DEMO_CHECKOUT=false
ALLOW_DEV_EMAIL_FALLBACK=false
EXPOSE_DEV_AUTH_CODE=false

# Payment gateway. Use a TEST token for sandbox checkout.
PAYMENT_GATEWAY=mercadopago
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_USE_SANDBOX=true
BACKEND_PUBLIC_URL=http://localhost:3000
MERCADO_PAGO_NOTIFICATION_URL=

# SMTP settings. Configure these before testing with real users.
# Keep ALLOW_DEV_EMAIL_FALLBACK=false so verification codes only arrive by email.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TEST_TO=

# Optional OAuth credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# LinkedIn callback URL for local development:
# http://localhost:3000/api/auth/oauth/linkedin/callback
# Enable the "Sign In with LinkedIn using OpenID Connect" product in the app.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:3000
